# ═══════════════════════════════════════════════════════════════════════════════
# ROS2 / C++ / CMake .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Colcon Build Artifacts ──────────────────────────────────────────────────
build/
install/
log/

# ─── CMake ───────────────────────────────────────────────────────────────────
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt

# ─── Compiled Objects ───────────────────────────────────────────────────────
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe

# ─── IDE / Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.cproject
.settings/
*.user
*.suo
*.ncb
*.opensdf
*.sdf

# ─── Doxygen Output ─────────────────────────────────────────────────────────
docs/generated/

# ─── OS Files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Python Cache ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ─── Test Results ────────────────────────────────────────────────────────────
Testing/
test_results/
*.gcda
*.gcno
*.gcov

# ─── Packages ────────────────────────────────────────────────────────────────
*.tar.gz
*.zip
*.deb
